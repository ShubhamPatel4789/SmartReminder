<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F4F8">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Title *" android:textColor="#555" android:textSize="13sp" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/et_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="e.g. Stand up and stretch"
            android:background="#FFFFFF" android:padding="12dp" android:textSize="15sp"
            android:inputType="textCapSentences"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Note / Message" android:textColor="#555" android:textSize="13sp"
            android:paddingTop="12dp" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/et_msg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Optional details"
            android:background="#FFFFFF" android:padding="12dp" android:textSize="15sp"
            android:minLines="2" android:gravity="top|left" android:inputType="textMultiLine"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Category" android:textColor="#555" android:textSize="13sp"
            android:paddingTop="12dp" android:paddingBottom="4dp"/>
        <Spinner android:id="@+id/sp_cat" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="#FFFFFF" android:padding="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Date" android:textColor="#555" android:textSize="13sp"
            android:paddingTop="16dp" android:paddingBottom="6dp"/>
        <Button android:id="@+id/btn_date" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="#FFFFFF" android:textColor="#1A1A1A" android:textSize="14sp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Time" android:textColor="#555" android:textSize="13sp"
            android:paddingTop="12dp" android:paddingBottom="6dp"/>
        <Button android:id="@+id/btn_time" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="#FFFFFF" android:textColor="#1A1A1A" android:textSize="14sp"/>

        <CheckBox android:id="@+id/cb_rec" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Make this recurring"
            android:textSize="15sp" android:paddingTop="16dp" android:textColor="#1A1A1A"/>

        <RadioGroup android:id="@+id/rg_type" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:visibility="gone"
            android:paddingLeft="16dp" android:paddingTop="8dp">
            <RadioButton android:id="@+id/rb_daily" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Daily" android:checked="true"/>
            <RadioButton android:id="@+id/rb_weekly" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Weekly (pick days)"/>
            <RadioButton android:id="@+id/rb_monthly" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Monthly (pick day of month)"/>
        </RadioGroup>

        <LinearLayout android:id="@+id/ll_week" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:visibility="gone" android:paddingLeft="16dp" android:paddingTop="8dp">
            <CheckBox android:id="@+id/cb_sun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sun"/>
            <CheckBox android:id="@+id/cb_mon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mon"/>
            <CheckBox android:id="@+id/cb_tue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tue"/>
            <CheckBox android:id="@+id/cb_wed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Wed"/>
            <CheckBox android:id="@+id/cb_thu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Thu"/>
            <CheckBox android:id="@+id/cb_fri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fri"/>
            <CheckBox android:id="@+id/cb_sat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sat"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/ll_month" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:visibility="gone" android:paddingLeft="16dp" android:paddingTop="8dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Day of month: " android:textSize="14sp"/>
            <NumberPicker android:id="@+id/np_dom" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button android:id="@+id/btn_save" android:layout_width="match_parent"
            android:layout_height="52dp" android:layout_marginTop="24dp"
            android:text="SAVE REMINDER" android:textColor="#FFFFFF"
            android:background="#27AE60" android:textStyle="bold" android:textSize="15sp"/>
    </LinearLayout>
</ScrollView>
